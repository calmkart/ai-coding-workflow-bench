<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Benchmark Report: {{ .Tag }}</title>
<style>
body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; max-width: 960px; margin: 0 auto; padding: 20px; color: #24292e; line-height: 1.5; }
h1 { border-bottom: 1px solid #e1e4e8; padding-bottom: 8px; }
h2 { border-bottom: 1px solid #e1e4e8; padding-bottom: 4px; margin-top: 24px; }
h3 { margin-top: 20px; }
table { border-collapse: collapse; width: 100%; margin-bottom: 16px; }
th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
th { background: #f5f5f5; font-weight: 600; }
tr:nth-child(even) { background: #fafbfc; }
.pass { color: #22863a; font-weight: 600; }
.fail { color: #cb2431; font-weight: 600; }
.warn { color: #b08800; }
.meta { color: #586069; font-size: 0.9em; margin-bottom: 16px; }
.warning-box { background: #fffbdd; border: 1px solid #f9c513; border-radius: 4px; padding: 8px 12px; margin-bottom: 16px; }
.bar-container { display: inline-block; width: 120px; height: 20px; background: #e1e4e8; border-radius: 3px; vertical-align: middle; overflow: hidden; }
.bar { height: 20px; background: #0366d6; display: inline-block; border-radius: 3px 0 0 3px; }
.bar-label { display: inline-block; margin-left: 6px; font-size: 0.85em; vertical-align: middle; }
.rate-green { background-color: #dcffe4; }
.rate-yellow { background-color: #fff5b1; }
.rate-red { background-color: #ffdce0; }
</style>
</head>
<body>
<h1>Benchmark Report: {{ .Tag }}</h1>
<p class="meta">Workflow: {{ .Workflow }} | Date: {{ .Date }} | Runs/task: {{ .RunsPerTask }}</p>
{{ if .LowSampleWarning }}<div class="warning-box">{{ .LowSampleWarning }}</div>{{ end }}

<h2>Overall</h2>
<table>
<tr><th>Metric</th><th>Value</th></tr>
<tr><td>Tasks</td><td>{{ .TotalTasks }}</td></tr>
<tr><td>Pass Rate (L4 E2E)</td><td>{{ .PassRateCI }}</td></tr>
<tr><td>Avg Correctness</td><td>{{ printf "%.2f" .AvgCorrectness }}</td></tr>
{{- if .AvgWallTime }}
<tr><td>Avg Wall Time</td><td>{{ .AvgWallTime }}</td></tr>
{{- end }}
{{- if .AvgTokens }}
<tr><td>Avg Tokens</td><td>{{ .AvgTokens }}</td></tr>
{{- end }}
{{- if .TotalCost }}
<tr><td>Est. Total Cost</td><td>{{ .TotalCost }}</td></tr>
{{- end }}
</table>

{{ if .HasRubric }}
<h2>Code Quality (LLM Judge)</h2>
<table>
<tr><th>Dimension</th><th>Score</th><th>Bar</th></tr>
<tr><td>Correctness</td><td>{{ printf "%.1f" .Rubric.Correctness }}/5</td><td><span class="bar-container"><span class="bar" style="width: {{ rubricPct .Rubric.Correctness }}%;"></span></span><span class="bar-label">{{ printf "%.0f" (rubricPct .Rubric.Correctness) }}%</span></td></tr>
<tr><td>Readability</td><td>{{ printf "%.1f" .Rubric.Readability }}/5</td><td><span class="bar-container"><span class="bar" style="width: {{ rubricPct .Rubric.Readability }}%;"></span></span><span class="bar-label">{{ printf "%.0f" (rubricPct .Rubric.Readability) }}%</span></td></tr>
<tr><td>Simplicity</td><td>{{ printf "%.1f" .Rubric.Simplicity }}/5</td><td><span class="bar-container"><span class="bar" style="width: {{ rubricPct .Rubric.Simplicity }}%;"></span></span><span class="bar-label">{{ printf "%.0f" (rubricPct .Rubric.Simplicity) }}%</span></td></tr>
<tr><td>Robustness</td><td>{{ printf "%.1f" .Rubric.Robustness }}/5</td><td><span class="bar-container"><span class="bar" style="width: {{ rubricPct .Rubric.Robustness }}%;"></span></span><span class="bar-label">{{ printf "%.0f" (rubricPct .Rubric.Robustness) }}%</span></td></tr>
<tr><td>Minimality</td><td>{{ printf "%.1f" .Rubric.Minimality }}/5</td><td><span class="bar-container"><span class="bar" style="width: {{ rubricPct .Rubric.Minimality }}%;"></span></span><span class="bar-label">{{ printf "%.0f" (rubricPct .Rubric.Minimality) }}%</span></td></tr>
<tr><td>Maintainability</td><td>{{ printf "%.1f" .Rubric.Maintainability }}/5</td><td><span class="bar-container"><span class="bar" style="width: {{ rubricPct .Rubric.Maintainability }}%;"></span></span><span class="bar-label">{{ printf "%.0f" (rubricPct .Rubric.Maintainability) }}%</span></td></tr>
<tr><td><strong>Composite</strong></td><td><strong>{{ printf "%.1f" .Rubric.Composite }}/5</strong></td><td><span class="bar-container"><span class="bar" style="width: {{ rubricPct .Rubric.Composite }}%;"></span></span><span class="bar-label">{{ printf "%.0f" (rubricPct .Rubric.Composite) }}%</span></td></tr>
<tr><td>Go Idioms</td><td>{{ printf "%.1f" .Rubric.GoIdioms }}/5</td><td><span class="bar-container"><span class="bar" style="width: {{ rubricPct .Rubric.GoIdioms }}%;"></span></span><span class="bar-label">{{ printf "%.0f" (rubricPct .Rubric.GoIdioms) }}%</span></td></tr>
</table>
{{ end }}

{{ if .TierGroups }}
<h2>Per-Tier Summary</h2>
<table>
<tr><th>Tier</th><th>Tasks</th><th>Pass Rate</th><th>Avg Correctness</th></tr>
{{ range .TierGroups -}}
<tr><td>T{{ .Tier }}</td><td>{{ .TaskCount }}</td><td class="{{ passRateClass .PassRate }}">{{ .PassRate }}</td><td>{{ .AvgCorrectness }}</td></tr>
{{ end -}}
</table>
{{ end }}

<h2>Per-Task Detail</h2>
{{ if .TaskGroups }}
{{ range .TaskGroups }}
<h3>{{ .ID }} ({{ .PassCount }}/{{ .RunCount }} passed, avg={{ printf "%.2f" .AvgCorrectness }})</h3>
<table>
<tr><th>Run</th><th>Tier</th><th>Type</th><th>L1</th><th>L2</th><th>L3</th><th>L4</th><th>Correctness</th></tr>
{{ range .Runs -}}
<tr>
<td>#{{ .RunNumber }}</td>
<td>T{{ .Tier }}</td>
<td>{{ .Type }}</td>
<td>{{ if .L1 }}<span class="pass">PASS</span>{{ else }}<span class="fail">FAIL</span>{{ end }}</td>
<td>{{ .L2Pass }}/{{ .L2Total }}</td>
<td>{{ .L3Issues }}</td>
<td>{{ .L4Pass }}/{{ .L4Total }}</td>
<td>{{ if .L1 }}{{ printf "%.2f" .Correctness }}{{ else }}<span class="fail">{{ printf "%.2f" .Correctness }}</span>{{ end }}</td>
</tr>
{{ end -}}
</table>
{{ end }}
{{ else }}
<table>
<tr><th>Task</th><th>Tier</th><th>Type</th><th>L1</th><th>L2</th><th>L3</th><th>L4</th><th>Correctness</th></tr>
{{ range .Tasks -}}
<tr>
<td>{{ .ID }}</td>
<td>T{{ .Tier }}</td>
<td>{{ .Type }}</td>
<td>{{ if .L1 }}<span class="pass">PASS</span>{{ else }}<span class="fail">FAIL</span>{{ end }}</td>
<td>{{ .L2Pass }}/{{ .L2Total }}</td>
<td>{{ .L3Issues }}</td>
<td>{{ .L4Pass }}/{{ .L4Total }}</td>
<td>{{ if .L1 }}{{ printf "%.2f" .Correctness }}{{ else }}<span class="fail">{{ printf "%.2f" .Correctness }}</span>{{ end }}</td>
</tr>
{{ end -}}
</table>
{{ end }}

{{ if .StabilityData }}
<h2>Stability</h2>
<table>
<tr><th>Task</th><th>Pass/Total</th><th>Stability</th></tr>
{{ range .StabilityData -}}
<tr><td>{{ .TaskID }}</td><td>{{ .PassCount }}/{{ .TotalRuns }}</td><td>{{ .Stability }}</td></tr>
{{ end -}}
</table>
{{ end }}
</body>
</html>
