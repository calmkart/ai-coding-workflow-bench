package main

import (
	"bytes"
	"strings"
	"testing"
)

func TestBenchE2E(t *testing.T) {
	t.Run("version_outputs_version_string", func(t *testing.T) {
		var buf bytes.Buffer
		err := runCmd([]string{"version"}, &buf)
		if err != nil {
			t.Fatalf("version command returned error: %v", err)
		}
		output := buf.String()
		if !strings.Contains(output, "v0.1.0") {
			t.Fatalf("version output should contain v0.1.0, got %q", output)
		}
	})

	t.Run("version_contains_name", func(t *testing.T) {
		var buf bytes.Buffer
		err := runCmd([]string{"version"}, &buf)
		if err != nil {
			t.Fatalf("version command returned error: %v", err)
		}
		output := buf.String()
		if !strings.Contains(output, "taskcli") {
			t.Fatalf("version output should contain 'taskcli', got %q", output)
		}
	})

	t.Run("list_still_works", func(t *testing.T) {
		var buf bytes.Buffer
		err := runCmd([]string{"list"}, &buf)
		if err != nil {
			t.Fatalf("list command returned error: %v", err)
		}
	})

	t.Run("unknown_cmd_still_errors", func(t *testing.T) {
		var buf bytes.Buffer
		err := runCmd([]string{"foobar"}, &buf)
		if err == nil {
			t.Fatal("expected error for unknown command")
		}
	})
}
