package main

import (
	"bytes"
	"strings"
	"testing"
)

func TestBenchE2E(t *testing.T) {
	tasks := []Task{
		{ID: 1, Title: "Buy groceries", Status: "done"},
		{ID: 2, Title: "Write documentation for the API", Status: "pending"},
		{ID: 3, Title: "Fix bug", Status: "in-progress"},
	}

	t.Run("output_has_header", func(t *testing.T) {
		var buf bytes.Buffer
		formatTasks(tasks, &buf)
		output := buf.String()

		if !strings.Contains(output, "ID") {
			t.Fatal("output should contain ID header")
		}
		if !strings.Contains(output, "Title") {
			t.Fatal("output should contain Title header")
		}
		if !strings.Contains(output, "Status") {
			t.Fatal("output should contain Status header")
		}
	})

	t.Run("columns_are_aligned", func(t *testing.T) {
		var buf bytes.Buffer
		formatTasks(tasks, &buf)
		lines := strings.Split(strings.TrimSpace(buf.String()), "\n")

		if len(lines) < 4 {
			t.Fatalf("expected at least 4 lines (header + 3 tasks), got %d", len(lines))
		}

		// Find where "Status" column starts in each line
		// All "Status" values should start at roughly the same position
		headerStatusIdx := strings.Index(lines[0], "Status")
		if headerStatusIdx < 0 {
			t.Fatal("header missing 'Status' column")
		}

		for i := 1; i < len(lines); i++ {
			line := lines[i]
			task := tasks[i-1]

			statusIdx := strings.Index(line, task.Status)
			if statusIdx < 0 {
				t.Fatalf("line %d missing status %q: %q", i, task.Status, line)
			}

			// Status column should be aligned - within a few chars of header position
			diff := statusIdx - headerStatusIdx
			if diff < -2 || diff > 2 {
				t.Fatalf("column misaligned: header Status at %d, row %d Status at %d\nHeader: %q\nRow:    %q",
					headerStatusIdx, i, statusIdx, lines[0], line)
			}
		}
	})

	t.Run("all_tasks_present", func(t *testing.T) {
		var buf bytes.Buffer
		formatTasks(tasks, &buf)
		output := buf.String()

		for _, task := range tasks {
			if !strings.Contains(output, task.Title) {
				t.Fatalf("output missing task title: %s", task.Title)
			}
			if !strings.Contains(output, task.Status) {
				t.Fatalf("output missing task status: %s", task.Status)
			}
		}
	})

	t.Run("empty_tasks", func(t *testing.T) {
		var buf bytes.Buffer
		formatTasks([]Task{}, &buf)
		output := buf.String()

		if !strings.Contains(output, "ID") {
			t.Fatal("empty list should still have header")
		}
	})
}
