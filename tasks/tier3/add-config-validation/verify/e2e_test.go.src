package main

import (
	"os"
	"path/filepath"
	"strings"
	"testing"
)

func TestBenchE2E(t *testing.T) {
	t.Run("default_config", func(t *testing.T) {
		cfg := DefaultConfig()
		if cfg.DataDir == "" {
			t.Fatal("expected non-empty default data dir")
		}
		if cfg.MaxTasks <= 0 {
			t.Fatalf("expected positive max tasks, got %d", cfg.MaxTasks)
		}
		if cfg.OutputFormat == "" {
			t.Fatal("expected non-empty default output format")
		}
	})

	t.Run("validate_valid_config", func(t *testing.T) {
		cfg := DefaultConfig()
		err := cfg.Validate()
		if err != nil {
			t.Fatalf("default config should be valid: %v", err)
		}
	})

	t.Run("validate_empty_data_dir", func(t *testing.T) {
		cfg := DefaultConfig()
		cfg.DataDir = ""
		err := cfg.Validate()
		if err == nil {
			t.Fatal("expected validation error for empty data dir")
		}
	})

	t.Run("validate_invalid_max_tasks", func(t *testing.T) {
		cfg := DefaultConfig()
		cfg.MaxTasks = -1
		err := cfg.Validate()
		if err == nil {
			t.Fatal("expected validation error for negative max tasks")
		}
	})

	t.Run("validate_invalid_format", func(t *testing.T) {
		cfg := DefaultConfig()
		cfg.OutputFormat = "yaml"
		err := cfg.Validate()
		if err == nil {
			t.Fatal("expected validation error for invalid format")
		}
	})

	t.Run("validate_multiple_errors", func(t *testing.T) {
		cfg := Config{
			DataDir:      "",
			MaxTasks:     0,
			OutputFormat: "invalid",
		}
		err := cfg.Validate()
		if err == nil {
			t.Fatal("expected validation errors")
		}

		// Should aggregate multiple errors
		errStr := err.Error()
		parts := strings.Split(errStr, ";")
		if len(parts) < 2 {
			// Check if it contains multiple error indicators
			if !strings.Contains(errStr, "data_dir") || !strings.Contains(errStr, "max_tasks") {
				t.Fatalf("expected multiple errors, got: %s", errStr)
			}
		}
	})

	t.Run("merge_config", func(t *testing.T) {
		base := DefaultConfig()
		override := &Config{
			MaxTasks: 500,
		}

		merged := MergeConfig(base, override)
		if merged.MaxTasks != 500 {
			t.Fatalf("expected 500 from override, got %d", merged.MaxTasks)
		}
		if merged.DataDir != base.DataDir {
			t.Fatalf("expected base data dir, got %s", merged.DataDir)
		}
	})

	t.Run("load_and_validate", func(t *testing.T) {
		dir := t.TempDir()
		path := filepath.Join(dir, "config.json")
		os.WriteFile(path, []byte(`{"data_dir":"/tmp/test","max_tasks":50,"output_format":"json"}`), 0644)

		cfg, err := LoadAndValidate(path)
		if err != nil {
			t.Fatalf("expected valid config: %v", err)
		}
		if cfg.DataDir != "/tmp/test" {
			t.Fatalf("expected /tmp/test, got %s", cfg.DataDir)
		}
	})

	t.Run("load_and_validate_invalid", func(t *testing.T) {
		dir := t.TempDir()
		path := filepath.Join(dir, "config.json")
		os.WriteFile(path, []byte(`{"max_tasks":-1}`), 0644)

		_, err := LoadAndValidate(path)
		if err == nil {
			t.Fatal("expected validation error")
		}
	})

	t.Run("load_missing_file_uses_defaults", func(t *testing.T) {
		cfg, err := LoadAndValidate("/nonexistent/config.json")
		// Should fall back to defaults and validate
		if err != nil {
			// If it returns an error for missing file, that's also acceptable
			// as long as DefaultConfig().Validate() passes
			defCfg := DefaultConfig()
			if defErr := defCfg.Validate(); defErr != nil {
				t.Fatalf("default config should be valid: %v", defErr)
			}
			return
		}
		if cfg.DataDir == "" {
			t.Fatal("expected defaults applied")
		}
	})

	t.Run("validation_errors_type", func(t *testing.T) {
		cfg := Config{
			DataDir:      "",
			MaxTasks:     0,
			OutputFormat: "bad",
		}
		err := cfg.Validate()
		if err == nil {
			t.Fatal("expected error")
		}

		var ve ValidationErrors
		// Check if the error message aggregates multiple issues
		_ = ve
		errStr := err.Error()
		if errStr == "" {
			t.Fatal("error message should not be empty")
		}
	})
}
