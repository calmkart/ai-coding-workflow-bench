package collections

import (
	"testing"
)

func TestBenchE2E(t *testing.T) {
	t.Run("map_int_to_string", func(t *testing.T) {
		input := []int{1, 2, 3}
		result := Map(input, func(v int) string {
			return string(rune('a' + v - 1))
		})
		if len(result) != 3 {
			t.Fatalf("expected 3, got %d", len(result))
		}
		if result[0] != "a" {
			t.Fatalf("expected 'a', got '%s'", result[0])
		}
	})

	t.Run("map_nil_input", func(t *testing.T) {
		result := Map(nil, func(v int) int { return v })
		if result == nil {
			t.Fatal("expected non-nil empty slice")
		}
		if len(result) != 0 {
			t.Fatalf("expected 0, got %d", len(result))
		}
	})

	t.Run("filter_even", func(t *testing.T) {
		input := []int{1, 2, 3, 4, 5, 6}
		result := Filter(input, func(v int) bool { return v%2 == 0 })
		if len(result) != 3 {
			t.Fatalf("expected 3 even numbers, got %d", len(result))
		}
		if result[0] != 2 || result[1] != 4 || result[2] != 6 {
			t.Fatalf("expected [2,4,6], got %v", result)
		}
	})

	t.Run("filter_none_match", func(t *testing.T) {
		input := []int{1, 3, 5}
		result := Filter(input, func(v int) bool { return v%2 == 0 })
		if result == nil {
			t.Fatal("expected non-nil empty slice")
		}
		if len(result) != 0 {
			t.Fatalf("expected 0, got %d", len(result))
		}
	})

	t.Run("reduce_sum", func(t *testing.T) {
		input := []int{1, 2, 3, 4, 5}
		sum := Reduce(input, 0, func(acc int, v int) int { return acc + v })
		if sum != 15 {
			t.Fatalf("expected 15, got %d", sum)
		}
	})

	t.Run("reduce_different_types", func(t *testing.T) {
		input := []string{"hello", " ", "world"}
		result := Reduce(input, "", func(acc string, v string) string { return acc + v })
		if result != "hello world" {
			t.Fatalf("expected 'hello world', got '%s'", result)
		}
	})

	t.Run("contains", func(t *testing.T) {
		input := []string{"a", "b", "c"}
		if !Contains(input, "b") {
			t.Fatal("expected to contain 'b'")
		}
		if Contains(input, "d") {
			t.Fatal("should not contain 'd'")
		}
	})

	t.Run("unique", func(t *testing.T) {
		input := []int{1, 2, 2, 3, 3, 3, 4}
		result := Unique(input)
		if len(result) != 4 {
			t.Fatalf("expected 4 unique, got %d", len(result))
		}
	})

	t.Run("unique_preserves_order", func(t *testing.T) {
		input := []string{"c", "a", "b", "a", "c"}
		result := Unique(input)
		if len(result) != 3 {
			t.Fatalf("expected 3, got %d", len(result))
		}
		if result[0] != "c" || result[1] != "a" || result[2] != "b" {
			t.Fatalf("expected [c,a,b], got %v", result)
		}
	})

	t.Run("groupby", func(t *testing.T) {
		type Person struct {
			Name string
			Age  int
		}
		input := []Person{
			{"alice", 20},
			{"bob", 20},
			{"carol", 30},
		}
		groups := GroupBy(input, func(p Person) int { return p.Age })
		if len(groups) != 2 {
			t.Fatalf("expected 2 groups, got %d", len(groups))
		}
		if len(groups[20]) != 2 {
			t.Fatalf("expected 2 people age 20, got %d", len(groups[20]))
		}
		if len(groups[30]) != 1 {
			t.Fatalf("expected 1 person age 30, got %d", len(groups[30]))
		}
	})

	t.Run("unique_nil", func(t *testing.T) {
		result := Unique[int](nil)
		if result == nil {
			t.Fatal("expected non-nil empty slice")
		}
		if len(result) != 0 {
			t.Fatalf("expected 0, got %d", len(result))
		}
	})

	t.Run("filter_nil", func(t *testing.T) {
		result := Filter(nil, func(v int) bool { return true })
		if result == nil {
			t.Fatal("expected non-nil empty slice")
		}
	})
}
