package main

import (
	"encoding/json"
	"net/http"
	"net/http/httptest"
	"strings"
	"testing"
)

func TestBenchE2E(t *testing.T) {
	mux := setupRouter()
	ts := httptest.NewServer(mux)
	defer ts.Close()

	t.Run("batch_create", func(t *testing.T) {
		body := `{"operations":[
			{"action":"create","data":{"title":"batch 1"}},
			{"action":"create","data":{"title":"batch 2"}},
			{"action":"create","data":{"title":"batch 3"}}
		]}`
		resp, err := http.Post(ts.URL+"/todos/batch", "application/json",
			strings.NewReader(body))
		if err != nil {
			t.Fatal(err)
		}
		defer resp.Body.Close()
		if resp.StatusCode != http.StatusOK {
			t.Fatalf("expected 200, got %d", resp.StatusCode)
		}

		var result map[string]any
		json.NewDecoder(resp.Body).Decode(&result)
		results, ok := result["results"].([]any)
		if !ok {
			t.Fatalf("expected results array, got %v", result)
		}
		if len(results) != 3 {
			t.Fatalf("expected 3 results, got %d", len(results))
		}
	})

	t.Run("verify_batch_created", func(t *testing.T) {
		resp, err := http.Get(ts.URL + "/todos")
		if err != nil {
			t.Fatal(err)
		}
		defer resp.Body.Close()

		var todos []map[string]any
		json.NewDecoder(resp.Body).Decode(&todos)
		if len(todos) < 3 {
			t.Fatalf("expected at least 3 todos, got %d", len(todos))
		}
	})

	t.Run("batch_mixed_operations", func(t *testing.T) {
		mux2 := setupRouter()
		ts2 := httptest.NewServer(mux2)
		defer ts2.Close()

		// First create one
		resp, _ := http.Post(ts2.URL+"/todos", "application/json",
			strings.NewReader(`{"title":"original"}`))
		resp.Body.Close()

		// Batch: create + update + delete
		body := `{"operations":[
			{"action":"create","data":{"title":"new item"}},
			{"action":"update","data":{"id":1,"title":"updated","done":true}},
			{"action":"delete","data":{"id":1}}
		]}`
		resp2, err := http.Post(ts2.URL+"/todos/batch", "application/json",
			strings.NewReader(body))
		if err != nil {
			t.Fatal(err)
		}
		defer resp2.Body.Close()
		if resp2.StatusCode != http.StatusOK {
			t.Fatalf("expected 200, got %d", resp2.StatusCode)
		}
	})

	t.Run("batch_validation_failure_rolls_back", func(t *testing.T) {
		mux3 := setupRouter()
		ts3 := httptest.NewServer(mux3)
		defer ts3.Close()

		// Batch with invalid operation (empty title)
		body := `{"operations":[
			{"action":"create","data":{"title":"good one"}},
			{"action":"create","data":{"title":""}}
		]}`
		resp, err := http.Post(ts3.URL+"/todos/batch", "application/json",
			strings.NewReader(body))
		if err != nil {
			t.Fatal(err)
		}
		defer resp.Body.Close()
		if resp.StatusCode != http.StatusBadRequest {
			t.Fatalf("expected 400 for validation failure, got %d", resp.StatusCode)
		}

		// Verify nothing was created (rollback)
		listResp, _ := http.Get(ts3.URL + "/todos")
		defer listResp.Body.Close()
		var todos []map[string]any
		json.NewDecoder(listResp.Body).Decode(&todos)
		if len(todos) != 0 {
			t.Fatalf("expected 0 todos after rollback, got %d", len(todos))
		}
	})

	t.Run("batch_too_large", func(t *testing.T) {
		ops := make([]map[string]any, 101)
		for i := range ops {
			ops[i] = map[string]any{"action": "create", "data": map[string]any{"title": "x"}}
		}
		body, _ := json.Marshal(map[string]any{"operations": ops})
		resp, err := http.Post(ts.URL+"/todos/batch", "application/json",
			strings.NewReader(string(body)))
		if err != nil {
			t.Fatal(err)
		}
		defer resp.Body.Close()
		if resp.StatusCode != http.StatusBadRequest {
			t.Fatalf("expected 400 for too many ops, got %d", resp.StatusCode)
		}
	})

	t.Run("single_crud_still_works", func(t *testing.T) {
		resp, err := http.Get(ts.URL + "/health")
		if err != nil {
			t.Fatal(err)
		}
		defer resp.Body.Close()
		if resp.StatusCode != http.StatusOK {
			t.Fatalf("expected 200, got %d", resp.StatusCode)
		}
	})
}
