package circuitbreaker

import (
	"errors"
	"sync"
	"testing"
	"time"
)

var errTest = errors.New("test error")

func TestBenchE2E(t *testing.T) {
	t.Run("closed_executes_normally", func(t *testing.T) {
		cb := NewCircuitBreaker(Options{MaxFailures: 3, Timeout: time.Second})

		called := false
		err := cb.Execute(func() error {
			called = true
			return nil
		})

		if err != nil {
			t.Fatalf("expected nil, got %v", err)
		}
		if !called {
			t.Fatal("function was not called")
		}
		if cb.State() != StateClosed {
			t.Fatalf("expected closed, got %v", cb.State())
		}
	})

	t.Run("opens_after_max_failures", func(t *testing.T) {
		cb := NewCircuitBreaker(Options{MaxFailures: 3, Timeout: time.Second})

		for i := 0; i < 3; i++ {
			cb.Execute(func() error { return errTest })
		}

		if cb.State() != StateOpen {
			t.Fatalf("expected open after 3 failures, got %v", cb.State())
		}
	})

	t.Run("open_rejects_calls", func(t *testing.T) {
		cb := NewCircuitBreaker(Options{MaxFailures: 2, Timeout: time.Second})

		// Trip the breaker
		for i := 0; i < 2; i++ {
			cb.Execute(func() error { return errTest })
		}

		called := false
		err := cb.Execute(func() error {
			called = true
			return nil
		})

		if !errors.Is(err, ErrCircuitOpen) {
			t.Fatalf("expected ErrCircuitOpen, got %v", err)
		}
		if called {
			t.Fatal("function should not be called when open")
		}
	})

	t.Run("half_open_after_timeout", func(t *testing.T) {
		cb := NewCircuitBreaker(Options{MaxFailures: 2, Timeout: 50 * time.Millisecond})

		// Trip the breaker
		for i := 0; i < 2; i++ {
			cb.Execute(func() error { return errTest })
		}

		if cb.State() != StateOpen {
			t.Fatalf("expected open, got %v", cb.State())
		}

		// Wait for timeout
		time.Sleep(100 * time.Millisecond)

		// Next call should be allowed (half-open)
		err := cb.Execute(func() error { return nil })
		if err != nil {
			t.Fatalf("expected success in half-open, got %v", err)
		}
	})

	t.Run("half_open_success_closes", func(t *testing.T) {
		cb := NewCircuitBreaker(Options{MaxFailures: 2, Timeout: 50 * time.Millisecond})

		for i := 0; i < 2; i++ {
			cb.Execute(func() error { return errTest })
		}

		time.Sleep(100 * time.Millisecond)

		// Success in half-open should close
		cb.Execute(func() error { return nil })

		if cb.State() != StateClosed {
			t.Fatalf("expected closed after half-open success, got %v", cb.State())
		}
	})

	t.Run("half_open_failure_reopens", func(t *testing.T) {
		cb := NewCircuitBreaker(Options{MaxFailures: 2, Timeout: 50 * time.Millisecond})

		for i := 0; i < 2; i++ {
			cb.Execute(func() error { return errTest })
		}

		time.Sleep(100 * time.Millisecond)

		// Failure in half-open should reopen
		cb.Execute(func() error { return errTest })

		if cb.State() != StateOpen {
			t.Fatalf("expected open after half-open failure, got %v", cb.State())
		}
	})

	t.Run("reset", func(t *testing.T) {
		cb := NewCircuitBreaker(Options{MaxFailures: 2, Timeout: time.Second})

		for i := 0; i < 2; i++ {
			cb.Execute(func() error { return errTest })
		}

		cb.Reset()
		if cb.State() != StateClosed {
			t.Fatalf("expected closed after reset, got %v", cb.State())
		}

		err := cb.Execute(func() error { return nil })
		if err != nil {
			t.Fatalf("expected success after reset, got %v", err)
		}
	})

	t.Run("success_resets_failure_count", func(t *testing.T) {
		cb := NewCircuitBreaker(Options{MaxFailures: 3, Timeout: time.Second})

		cb.Execute(func() error { return errTest })
		cb.Execute(func() error { return errTest })
		cb.Execute(func() error { return nil }) // success resets count

		// Should still be closed
		if cb.State() != StateClosed {
			t.Fatalf("expected closed, got %v", cb.State())
		}

		cb.Execute(func() error { return errTest })
		cb.Execute(func() error { return errTest })

		// Only 2 consecutive failures, still closed
		if cb.State() != StateClosed {
			t.Fatalf("expected still closed, got %v", cb.State())
		}
	})

	t.Run("concurrent_safety", func(t *testing.T) {
		cb := NewCircuitBreaker(Options{MaxFailures: 100, Timeout: time.Second})
		var wg sync.WaitGroup

		for i := 0; i < 10; i++ {
			wg.Add(1)
			go func() {
				defer wg.Done()
				for j := 0; j < 50; j++ {
					cb.Execute(func() error { return nil })
					cb.State()
				}
			}()
		}

		wg.Wait()
	})
}
