package main

import (
	"os"
	"path/filepath"
	"strings"
	"testing"
)

func writePlugin(t *testing.T, dir, name, content string) {
	t.Helper()
	err := os.WriteFile(filepath.Join(dir, name+".json"), []byte(content), 0644)
	if err != nil {
		t.Fatal(err)
	}
}

func TestBenchE2E(t *testing.T) {
	t.Run("load_plugins_from_dir", func(t *testing.T) {
		dir := t.TempDir()
		writePlugin(t, dir, "greet", `{
			"name": "greet",
			"description": "Greet a user",
			"template": "Hello, {{.Args}}!"
		}`)

		plugins, err := LoadPlugins(dir)
		if err != nil {
			t.Fatal(err)
		}
		if len(plugins) != 1 {
			t.Fatalf("expected 1 plugin, got %d", len(plugins))
		}
		if plugins[0].Name != "greet" {
			t.Fatalf("expected name 'greet', got '%s'", plugins[0].Name)
		}
	})

	t.Run("execute_plugin_command", func(t *testing.T) {
		dir := t.TempDir()
		writePlugin(t, dir, "echo", `{
			"name": "echo",
			"description": "Echo args",
			"template": "Echo: {{.Args}}"
		}`)

		plugins, _ := LoadPlugins(dir)
		output, err := plugins[0].Execute([]string{"hello", "world"})
		if err != nil {
			t.Fatal(err)
		}
		if !strings.Contains(output, "hello") {
			t.Fatalf("expected output to contain 'hello', got: %s", output)
		}
	})

	t.Run("skip_invalid_plugin", func(t *testing.T) {
		dir := t.TempDir()
		// Valid plugin
		writePlugin(t, dir, "good", `{
			"name": "good",
			"description": "Valid",
			"template": "ok"
		}`)
		// Invalid JSON
		os.WriteFile(filepath.Join(dir, "bad.json"), []byte(`{invalid`), 0644)

		plugins, err := LoadPlugins(dir)
		if err != nil {
			t.Fatal(err)
		}
		if len(plugins) != 1 {
			t.Fatalf("expected 1 valid plugin, got %d", len(plugins))
		}
	})

	t.Run("skip_missing_name", func(t *testing.T) {
		dir := t.TempDir()
		writePlugin(t, dir, "noname", `{
			"description": "Missing name",
			"template": "test"
		}`)

		plugins, _ := LoadPlugins(dir)
		if len(plugins) != 0 {
			t.Fatalf("expected 0 plugins (missing name), got %d", len(plugins))
		}
	})

	t.Run("empty_dir", func(t *testing.T) {
		dir := t.TempDir()
		plugins, err := LoadPlugins(dir)
		if err != nil {
			t.Fatal(err)
		}
		if len(plugins) != 0 {
			t.Fatalf("expected 0 plugins, got %d", len(plugins))
		}
	})

	t.Run("nonexistent_dir", func(t *testing.T) {
		_, err := LoadPlugins("/nonexistent/path")
		if err == nil {
			t.Fatal("expected error for nonexistent dir")
		}
	})

	t.Run("multiple_plugins", func(t *testing.T) {
		dir := t.TempDir()
		writePlugin(t, dir, "a", `{"name":"a","description":"A","template":"A"}`)
		writePlugin(t, dir, "b", `{"name":"b","description":"B","template":"B"}`)
		writePlugin(t, dir, "c", `{"name":"c","description":"C","template":"C"}`)

		plugins, _ := LoadPlugins(dir)
		if len(plugins) != 3 {
			t.Fatalf("expected 3 plugins, got %d", len(plugins))
		}
	})
}
