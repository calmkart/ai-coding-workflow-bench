package main

import (
	"context"
	"net"
	"net/http"
	"strings"
	"testing"
	"time"
)

func TestBenchE2E(t *testing.T) {
	t.Run("setupRouter_still_works", func(t *testing.T) {
		mux := setupRouter()
		// Start server manually
		srv := &http.Server{Handler: mux}
		ln, err := net.Listen("tcp", "127.0.0.1:0")
		if err != nil {
			t.Fatal(err)
		}
		go srv.Serve(ln)
		defer srv.Shutdown(context.Background())

		baseURL := "http://" + ln.Addr().String()

		// Create a todo
		resp, err := http.Post(baseURL+"/todos", "application/json",
			strings.NewReader(`{"title":"test","done":false}`))
		if err != nil {
			t.Fatal(err)
		}
		resp.Body.Close()
		if resp.StatusCode != http.StatusCreated {
			t.Fatalf("expected 201, got %d", resp.StatusCode)
		}

		// List todos
		resp, err = http.Get(baseURL + "/todos")
		if err != nil {
			t.Fatal(err)
		}
		resp.Body.Close()
		if resp.StatusCode != http.StatusOK {
			t.Fatalf("expected 200, got %d", resp.StatusCode)
		}
	})

	t.Run("graceful_shutdown", func(t *testing.T) {
		mux := setupRouter()
		srv := &http.Server{Handler: mux}
		ln, err := net.Listen("tcp", "127.0.0.1:0")
		if err != nil {
			t.Fatal(err)
		}
		go srv.Serve(ln)

		baseURL := "http://" + ln.Addr().String()

		// Verify server is running
		resp, err := http.Get(baseURL + "/todos")
		if err != nil {
			t.Fatal(err)
		}
		resp.Body.Close()

		// Graceful shutdown
		ctx, cancel := context.WithTimeout(context.Background(), 5*time.Second)
		defer cancel()
		if err := srv.Shutdown(ctx); err != nil {
			t.Fatalf("shutdown failed: %v", err)
		}

		// Verify server is no longer accepting connections
		_, err = http.Get(baseURL + "/todos")
		if err == nil {
			t.Fatal("expected connection error after shutdown")
		}
	})
}
