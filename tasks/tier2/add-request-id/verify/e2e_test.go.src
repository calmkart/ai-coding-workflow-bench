package main

import (
	"net/http"
	"net/http/httptest"
	"regexp"
	"strings"
	"testing"
)

var uuidRegex = regexp.MustCompile(`^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$`)

func TestBenchE2E(t *testing.T) {
	mux := setupRouter()
	ts := httptest.NewServer(mux)
	defer ts.Close()

	t.Run("response_has_request_id", func(t *testing.T) {
		resp, err := http.Get(ts.URL + "/todos")
		if err != nil {
			t.Fatal(err)
		}
		defer resp.Body.Close()

		rid := resp.Header.Get("X-Request-ID")
		if rid == "" {
			t.Fatal("missing X-Request-ID header")
		}
	})

	t.Run("request_id_is_uuid_v4", func(t *testing.T) {
		resp, err := http.Get(ts.URL + "/todos")
		if err != nil {
			t.Fatal(err)
		}
		defer resp.Body.Close()

		rid := resp.Header.Get("X-Request-ID")
		if !uuidRegex.MatchString(rid) {
			t.Fatalf("X-Request-ID is not UUID v4: %s", rid)
		}
	})

	t.Run("each_request_gets_unique_id", func(t *testing.T) {
		resp1, _ := http.Get(ts.URL + "/todos")
		resp1.Body.Close()
		resp2, _ := http.Get(ts.URL + "/todos")
		resp2.Body.Close()

		id1 := resp1.Header.Get("X-Request-ID")
		id2 := resp2.Header.Get("X-Request-ID")
		if id1 == id2 {
			t.Fatalf("two requests got same ID: %s", id1)
		}
	})

	t.Run("preserves_incoming_request_id", func(t *testing.T) {
		req, _ := http.NewRequest("GET", ts.URL+"/todos", nil)
		req.Header.Set("X-Request-ID", "my-custom-id-123")
		resp, err := http.DefaultClient.Do(req)
		if err != nil {
			t.Fatal(err)
		}
		defer resp.Body.Close()

		rid := resp.Header.Get("X-Request-ID")
		if rid != "my-custom-id-123" {
			t.Fatalf("expected preserved ID 'my-custom-id-123', got %s", rid)
		}
	})

	t.Run("post_has_request_id", func(t *testing.T) {
		resp, err := http.Post(ts.URL+"/todos", "application/json",
			strings.NewReader(`{"title":"test","done":false}`))
		if err != nil {
			t.Fatal(err)
		}
		defer resp.Body.Close()

		rid := resp.Header.Get("X-Request-ID")
		if rid == "" {
			t.Fatal("POST response missing X-Request-ID")
		}
	})
}
