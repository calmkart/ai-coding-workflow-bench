package ratelimiter

import (
	"testing"
	"time"
)

func TestBenchE2E(t *testing.T) {
	t.Run("burst_allowed", func(t *testing.T) {
		rl := NewRateLimiter(10, 5)

		// Should allow burst of 5
		for i := 0; i < 5; i++ {
			if !rl.Allow() {
				t.Fatalf("burst request %d should be allowed", i)
			}
		}
	})

	t.Run("exceeds_burst_denied", func(t *testing.T) {
		rl := NewRateLimiter(10, 3)

		// Consume all tokens
		for i := 0; i < 3; i++ {
			rl.Allow()
		}

		// Next should be denied
		if rl.Allow() {
			t.Fatal("should be denied after burst exhausted")
		}
	})

	t.Run("tokens_refill", func(t *testing.T) {
		rl := NewRateLimiter(100, 5) // 100 tokens/sec

		// Consume all tokens
		for i := 0; i < 5; i++ {
			rl.Allow()
		}

		// Wait for refill
		time.Sleep(60 * time.Millisecond) // ~6 tokens should be added

		if !rl.Allow() {
			t.Fatal("should be allowed after refill")
		}
	})

	t.Run("wait_blocks", func(t *testing.T) {
		rl := NewRateLimiter(100, 1) // 1 burst, 100/sec

		// Consume the token
		rl.Allow()

		start := time.Now()
		rl.Wait()
		elapsed := time.Since(start)

		// Should have waited ~10ms for one token at 100/sec
		if elapsed < 5*time.Millisecond {
			t.Fatalf("Wait should have blocked, elapsed: %v", elapsed)
		}
	})

	t.Run("tokens_dont_exceed_burst", func(t *testing.T) {
		rl := NewRateLimiter(1000, 3)

		// Wait to accumulate tokens
		time.Sleep(50 * time.Millisecond)

		// Should only allow burst amount, not more
		allowed := 0
		for i := 0; i < 10; i++ {
			if rl.Allow() {
				allowed++
			}
		}
		if allowed > 3 {
			t.Fatalf("should not exceed burst: allowed %d > 3", allowed)
		}
	})
}
