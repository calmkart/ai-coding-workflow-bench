package main

import (
	"bytes"
	"os/exec"
	"path/filepath"
	"strings"
	"testing"
)

func buildCLI(t *testing.T) string {
	t.Helper()
	dir := t.TempDir()
	bin := filepath.Join(dir, "taskcli")
	cmd := exec.Command("go", "build", "-o", bin, ".")
	cmd.Dir = "."
	out, err := cmd.CombinedOutput()
	if err != nil {
		t.Fatalf("build failed: %s\n%s", err, out)
	}
	return bin
}

func runCLI(t *testing.T, bin string, dir string, args ...string) (string, int) {
	t.Helper()
	cmd := exec.Command(bin, args...)
	cmd.Dir = dir
	out, err := cmd.CombinedOutput()
	exitCode := 0
	if err != nil {
		if ee, ok := err.(*exec.ExitError); ok {
			exitCode = ee.ExitCode()
		}
	}
	return string(out), exitCode
}

func TestBenchE2E(t *testing.T) {
	t.Run("progress_bar_format", func(t *testing.T) {
		var buf bytes.Buffer
		bar := NewProgressBar(10, &buf)
		bar.Update(5)

		out := buf.String()
		// Should contain progress bar like [=====>    ] 50% (5/10)
		if !strings.Contains(out, "50%") {
			t.Fatalf("expected 50%% in output: %s", out)
		}
		if !strings.Contains(out, "5") && !strings.Contains(out, "10") {
			t.Fatalf("expected count in output: %s", out)
		}
		if !strings.Contains(out, "[") || !strings.Contains(out, "]") {
			t.Fatalf("expected brackets in output: %s", out)
		}
	})

	t.Run("progress_bar_100_percent", func(t *testing.T) {
		var buf bytes.Buffer
		bar := NewProgressBar(10, &buf)
		bar.Update(10)

		out := buf.String()
		if !strings.Contains(out, "100%") {
			t.Fatalf("expected 100%% in output: %s", out)
		}
	})

	t.Run("progress_bar_0_percent", func(t *testing.T) {
		var buf bytes.Buffer
		bar := NewProgressBar(10, &buf)
		bar.Update(0)

		out := buf.String()
		if !strings.Contains(out, "0%") {
			t.Fatalf("expected 0%% in output: %s", out)
		}
	})

	t.Run("process_command", func(t *testing.T) {
		bin := buildCLI(t)
		dir := t.TempDir()
		runCLI(t, bin, dir, "add", "task 1")
		runCLI(t, bin, dir, "add", "task 2")
		runCLI(t, bin, dir, "add", "task 3")

		out, code := runCLI(t, bin, dir, "process")
		if code != 0 {
			t.Fatalf("expected exit 0, got %d: %s", code, out)
		}
		if !strings.Contains(out, "100%") {
			t.Fatalf("expected 100%% at end: %s", out)
		}
		if !strings.Contains(strings.ToLower(out), "complete") {
			t.Fatalf("expected 'complete' message: %s", out)
		}
	})
}
