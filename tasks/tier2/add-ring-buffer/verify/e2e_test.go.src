package ringbuffer

import "testing"

func TestBenchE2E(t *testing.T) {
	t.Run("write_and_read", func(t *testing.T) {
		rb := NewRingBuffer[int](3)
		rb.Write(1)
		rb.Write(2)

		v, ok := rb.Read()
		if !ok || v != 1 {
			t.Fatalf("expected 1, got %d (ok=%v)", v, ok)
		}

		v, ok = rb.Read()
		if !ok || v != 2 {
			t.Fatalf("expected 2, got %d (ok=%v)", v, ok)
		}
	})

	t.Run("read_empty", func(t *testing.T) {
		rb := NewRingBuffer[int](3)
		_, ok := rb.Read()
		if ok {
			t.Fatal("expected empty read to return false")
		}
	})

	t.Run("overwrite_oldest", func(t *testing.T) {
		rb := NewRingBuffer[int](3)
		rb.Write(1)
		rb.Write(2)
		rb.Write(3)
		rb.Write(4) // Overwrites 1

		v, ok := rb.Read()
		if !ok || v != 2 {
			t.Fatalf("expected 2 (oldest after overwrite), got %d", v)
		}
	})

	t.Run("len", func(t *testing.T) {
		rb := NewRingBuffer[string](3)
		if rb.Len() != 0 {
			t.Fatalf("expected 0, got %d", rb.Len())
		}
		rb.Write("a")
		rb.Write("b")
		if rb.Len() != 2 {
			t.Fatalf("expected 2, got %d", rb.Len())
		}
	})

	t.Run("is_full_empty", func(t *testing.T) {
		rb := NewRingBuffer[int](2)
		if !rb.IsEmpty() {
			t.Fatal("expected empty")
		}
		rb.Write(1)
		rb.Write(2)
		if !rb.IsFull() {
			t.Fatal("expected full")
		}
		if rb.IsEmpty() {
			t.Fatal("not expected empty when full")
		}
	})

	t.Run("to_slice", func(t *testing.T) {
		rb := NewRingBuffer[int](3)
		rb.Write(1)
		rb.Write(2)
		rb.Write(3)
		rb.Write(4) // Overwrites 1

		s := rb.ToSlice()
		if len(s) != 3 {
			t.Fatalf("expected 3 elements, got %d", len(s))
		}
		if s[0] != 2 || s[1] != 3 || s[2] != 4 {
			t.Fatalf("expected [2,3,4], got %v", s)
		}
	})

	t.Run("wrap_around_multiple_times", func(t *testing.T) {
		rb := NewRingBuffer[int](2)
		for i := 0; i < 10; i++ {
			rb.Write(i)
		}
		s := rb.ToSlice()
		if len(s) != 2 {
			t.Fatalf("expected 2, got %d", len(s))
		}
		if s[0] != 8 || s[1] != 9 {
			t.Fatalf("expected [8,9], got %v", s)
		}
	})
}
