package retry

import (
	"errors"
	"testing"
	"time"
)

func TestBenchE2E(t *testing.T) {
	t.Run("succeeds_on_first_try", func(t *testing.T) {
		calls := 0
		err := Retry(func() error {
			calls++
			return nil
		}, 3, time.Millisecond)

		if err != nil {
			t.Fatalf("expected nil, got %v", err)
		}
		if calls != 1 {
			t.Fatalf("expected 1 call, got %d", calls)
		}
	})

	t.Run("succeeds_on_third_try", func(t *testing.T) {
		calls := 0
		err := Retry(func() error {
			calls++
			if calls < 3 {
				return errors.New("not yet")
			}
			return nil
		}, 5, time.Millisecond)

		if err != nil {
			t.Fatalf("expected nil, got %v", err)
		}
		if calls != 3 {
			t.Fatalf("expected 3 calls, got %d", calls)
		}
	})

	t.Run("all_attempts_fail", func(t *testing.T) {
		calls := 0
		err := Retry(func() error {
			calls++
			return errors.New("always fail")
		}, 3, time.Millisecond)

		if err == nil {
			t.Fatal("expected error")
		}
		if calls != 3 {
			t.Fatalf("expected 3 calls, got %d", calls)
		}
	})

	t.Run("exponential_backoff", func(t *testing.T) {
		calls := 0
		start := time.Now()
		Retry(func() error {
			calls++
			if calls < 4 {
				return errors.New("fail")
			}
			return nil
		}, 5, 10*time.Millisecond)

		elapsed := time.Since(start)
		// 10ms + 20ms + 40ms = 70ms minimum
		if elapsed < 50*time.Millisecond {
			t.Fatalf("backoff too fast: %v", elapsed)
		}
	})

	t.Run("panic_on_zero_attempts", func(t *testing.T) {
		defer func() {
			if r := recover(); r == nil {
				t.Fatal("expected panic")
			}
		}()
		Retry(func() error { return nil }, 0, time.Millisecond)
	})

	t.Run("single_attempt", func(t *testing.T) {
		calls := 0
		err := Retry(func() error {
			calls++
			return errors.New("fail")
		}, 1, time.Millisecond)

		if err == nil {
			t.Fatal("expected error")
		}
		if calls != 1 {
			t.Fatalf("expected 1 call, got %d", calls)
		}
	})
}
