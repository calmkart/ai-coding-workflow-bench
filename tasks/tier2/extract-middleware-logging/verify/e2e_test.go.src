package main

import (
	"encoding/json"
	"net/http"
	"net/http/httptest"
	"strings"
	"testing"
)

func TestBenchE2E(t *testing.T) {
	mux := setupRouter()
	ts := httptest.NewServer(mux)
	defer ts.Close()

	// Test that all endpoints still work after middleware extraction
	t.Run("create_todo", func(t *testing.T) {
		resp, err := http.Post(ts.URL+"/todos", "application/json",
			strings.NewReader(`{"title":"test","done":false}`))
		if err != nil {
			t.Fatal(err)
		}
		defer resp.Body.Close()
		if resp.StatusCode != http.StatusCreated {
			t.Fatalf("expected 201, got %d", resp.StatusCode)
		}
	})

	t.Run("list_todos", func(t *testing.T) {
		resp, err := http.Get(ts.URL + "/todos")
		if err != nil {
			t.Fatal(err)
		}
		defer resp.Body.Close()
		if resp.StatusCode != http.StatusOK {
			t.Fatalf("expected 200, got %d", resp.StatusCode)
		}
		var todos []map[string]any
		json.NewDecoder(resp.Body).Decode(&todos)
		if len(todos) == 0 {
			t.Fatal("expected at least 1 todo")
		}
	})

	t.Run("get_todo", func(t *testing.T) {
		// Create a todo first
		resp, _ := http.Post(ts.URL+"/todos", "application/json",
			strings.NewReader(`{"title":"get-test","done":false}`))
		resp.Body.Close()

		var created map[string]any
		resp, _ = http.Post(ts.URL+"/todos", "application/json",
			strings.NewReader(`{"title":"get-test2","done":false}`))
		json.NewDecoder(resp.Body).Decode(&created)
		resp.Body.Close()

		resp, err := http.Get(ts.URL + "/todos/1")
		if err != nil {
			t.Fatal(err)
		}
		defer resp.Body.Close()
		if resp.StatusCode != http.StatusOK {
			t.Fatalf("expected 200, got %d", resp.StatusCode)
		}
	})

	t.Run("delete_todo", func(t *testing.T) {
		req, _ := http.NewRequest(http.MethodDelete, ts.URL+"/todos/1", nil)
		resp, err := http.DefaultClient.Do(req)
		if err != nil {
			t.Fatal(err)
		}
		defer resp.Body.Close()
		if resp.StatusCode != http.StatusNoContent {
			t.Fatalf("expected 204, got %d", resp.StatusCode)
		}
	})

	t.Run("handlers_no_log_printf", func(t *testing.T) {
		// This test verifies that the refactoring was done:
		// The middleware should exist and handlers should be clean.
		// We verify by checking the response works correctly through middleware.
		resp, err := http.Get(ts.URL + "/todos?page=1&page_size=5")
		if err != nil {
			t.Fatal(err)
		}
		defer resp.Body.Close()
		if resp.StatusCode != http.StatusOK {
			t.Fatalf("expected 200, got %d", resp.StatusCode)
		}
	})
}
