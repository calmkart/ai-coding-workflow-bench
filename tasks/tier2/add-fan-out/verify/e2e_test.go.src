package fanout

import (
	"sync/atomic"
	"testing"
	"time"
)

func TestBenchE2E(t *testing.T) {
	t.Run("results_correct", func(t *testing.T) {
		input := []int{1, 2, 3, 4, 5}
		results := FanOut(input, 3, func(n int) int { return n * 10 })

		expected := []int{10, 20, 30, 40, 50}
		for i, r := range results {
			if r != expected[i] {
				t.Fatalf("result[%d]: expected %d, got %d", i, expected[i], r)
			}
		}
	})

	t.Run("preserves_order", func(t *testing.T) {
		input := make([]int, 100)
		for i := range input {
			input[i] = i
		}

		results := FanOut(input, 8, func(n int) int {
			return n * 2
		})

		for i, r := range results {
			if r != i*2 {
				t.Fatalf("result[%d]: expected %d, got %d", i, i*2, r)
			}
		}
	})

	t.Run("actually_concurrent", func(t *testing.T) {
		var maxConcurrent atomic.Int32
		var current atomic.Int32

		input := make([]int, 20)
		for i := range input {
			input[i] = i
		}

		FanOut(input, 4, func(n int) int {
			c := current.Add(1)
			if c > maxConcurrent.Load() {
				maxConcurrent.Store(c)
			}
			time.Sleep(10 * time.Millisecond)
			current.Add(-1)
			return n
		})

		if maxConcurrent.Load() < 2 {
			t.Fatalf("expected concurrent execution, max concurrent was %d", maxConcurrent.Load())
		}
	})

	t.Run("empty_input", func(t *testing.T) {
		results := FanOut([]int{}, 4, func(n int) int { return n })
		if len(results) != 0 {
			t.Fatalf("expected 0, got %d", len(results))
		}
	})

	t.Run("single_worker", func(t *testing.T) {
		input := []string{"a", "b", "c"}
		results := FanOut(input, 1, func(s string) string { return s + "!" })

		expected := []string{"a!", "b!", "c!"}
		for i, r := range results {
			if r != expected[i] {
				t.Fatalf("result[%d]: expected %s, got %s", i, expected[i], r)
			}
		}
	})
}
